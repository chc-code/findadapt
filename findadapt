def get_parsed_reads(fn_fq, fh, ref_seq, enough_parsed_reads=1000, threads=10):
    total_max_reads_to_process = enough_parsed_reads * 3000 # at least find 1 matched read out of 3,000 processed reads
    n_processed_for_too_few = 1_000_000

    # check if the input data is a file
    try:
        with open(fn_fq) as f:
            f.seek(10)
    except:
        logger.info(f'input data is not file, multithread not supported, switch back to single core mode')
        threads = 1

    # initally, we split the file evenly, e.g. chunk10 will read from file_size * 0.9
    # however, the file.seek will take so long...
    # now, we'll send the sn to the chunk, only process the reads if the mod match with sn

    # if the fq file is already rich in miRNA, we should avoid using multithreads
    # because spawning the subprocess itself will take a while


    parsed_reads, n_processed, end_pos = process_chunk(fn_fq, ref_seq, None, total_max_reads_to_process=enough_parsed_reads * 100, n_processed_for_too_few=enough_parsed_reads * 100, enough_parsed_reads=enough_parsed_reads, threads=1, sn=None)

    if len(parsed_reads) > enough_parsed_reads:
        logger.info(green(f'the fastq is rich in expected sequence!'))
        return parsed_reads, n_processed


    if threads == 1:
        logger.info('single core mode')
        parsed_reads_new, n_processed_new = process_chunk(fn_fq, ref_seq, end_pos, total_max_reads_to_process=total_max_reads_to_process, n_processed_for_too_few=n_processed_for_too_few, enough_parsed_reads=enough_parsed_reads, threads=1, sn=None)[:2]
        parsed_reads += parsed_reads_new
        n_processed += n_processed_new
        return parsed_reads, n_processed

    if end_pos:
        enough_parsed_reads = enough_parsed_reads - len(parsed_reads)
    else:
        parsed_reads = []

    n_processed_for_too_few -= n_processed

    logger.debug(f'\t\ttest run end_pos = {end_pos},  current enough reads = {enough_parsed_reads}')

    n_tasks = min(threads, mp.cpu_count())
    chunk_args = []
    logger.info(green(f'\t\tprocessing  file using {n_tasks} cores'))

    for i in range(n_tasks):
        chunk_args.append((fn_fq, ref_seq, end_pos, total_max_reads_to_process, n_processed_for_too_few//n_tasks, enough_parsed_reads//n_tasks, threads, i))

    with mp.Pool(n_tasks) as p:
        chunk_results = p.starmap(process_chunk, chunk_args)

    # with open('/home/chenh19/s/exRNA/rerun/multithreads.pkl', 'wb') as o:
    #     pickle.dump(chunk_results, o)

    for i, i_n_processed, _end_pos in chunk_results:
        parsed_reads.extend(i)
        n_processed += i_n_processed
    return parsed_reads, n_processed


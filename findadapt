def verify_seq(seq, convert=False):
    seq = seq.strip().upper()
    if re.match(r'^[ATCGU]+$', seq):
        if convert:
            return re.sub('U', 'T', seq)
        return seq
    return None

def get_seqlist():
    seqlist = args.seq
    if seqlist is None or len(seqlist) == 0:
        return []

    res = []
    err = 0
    for i in seqlist:
        tmp = verify_seq(i)
        if tmp is not None:
            res.append(tmp)
        elif os.path.exists(i):
            invalid_seq = []
            with open(i) as f:
                for line in f:
                    tmp = verify_seq(line)
                    if tmp is None:
                        invalid_seq.append(line.strip())
                    else:
                        res.append(tmp)
            if len(invalid_seq) > 0:
                logger.error(f'invalid seq found in file {i}, first 10 seq are:\n' + '\n'.join(invalid_seq[:10]))
                err = 1
        else:
            logger.error(f'invalid -seq arg found, should be a sequence or filename')
            err = 1
    if err:
        sys.exit(1)
    return res


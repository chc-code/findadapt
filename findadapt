def get_most_expressed_smallRNA(organism, padding=10):
    """
    if the fastq is smallRNA seq, will use the most expressed miRNA
    padding: the downstream / upstream padding length of mature seq to get
    """
    fn = f'{pw_script}/data/most_expressed_miRNA.{organism}.txt'
    if not os.path.exists(fn):
        logger.error(f'the most expressed miRNA list file for {organism} is not found, please check: {fn}')
        return None

    mirlist = set()
    with open(fn) as f:
        for i in f:
            i = i.strip()
            if not i or i[0] in {'#', '"'}:
                continue
            mirlist.add(i.split('\t', 1)[0])

    logger.info(f'total top expressed miRNA for {organism} = {len(mirlist)}')
    mirna_seq_all = get_all_miRNA_seq()

    seq_not_found = []
    seqlist = []

    for mir in mirlist:
        mir = mir.lower()
        try:
            seqlist.append(mirna_seq_all['mature'][mir])
        except:
            if mir not in mirna_seq_all['usermap']:
                seq_not_found.append(mir)
            else:
                for mir_new in mirna_seq_all['usermap'][mir]:
                    seqlist.append(mirna_seq_all['mature'][mir_new])

    # logger.info(f'hsa-let-7a-5p in seqlist: {seq_tmp in seqlist}')
    if len(seq_not_found) > 0:
        logger.warning(f'fail to get the seq for the following miRNA, please check if the name is valid. n = {len(seq_not_found)},  first 10 = {seq_not_found[:10]}')

    return get_padding_seq(mirna_seq_all, seqlist, padding=padding)


